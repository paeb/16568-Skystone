    @Override
    public void loop() {
        //afterwards switch to state machines
        //get to
        switch(step) {
            case -4:
                xrail.setPower(0);
                approachBlock = true;
                DriveTrain(5);
                targetPosition = calculateTicks(5);
                step = 0;
                nextStep = 7;
                break;
            case -3:
                DriveTrain(-3);
                targetPosition = calculateTicks(-3);
                step = 0;
                nextStep = 3;
                break;
            case -2:
                if (!(fl.isBusy() && fr.isBusy() && bl.isBusy() && br.isBusy())){
                    fl.setPower(0);
                    fr.setPower(0);
                    bl.setPower(0);
                    br.setPower(0);
                    step = nextStep;
                } else {
                    double v1correction = 0;
                    double v2correction = 0;
                    double v3correction = 0;
                    double v4correction = 0;
                    angles = imu.getAngularOrientation(AxesReference.INTRINSIC, AxesOrder.ZYX, AngleUnit.DEGREES);
                    if (compareAngles(angles.angleUnit, angles.firstAngle) - strafeAngle < -acceptableRange){
                        v1correction = -increment;
                        v2correction = increment;
                        v3correction= -increment;
                        v4correction = increment;
                    } else if (compareAngles(angles.angleUnit, angles.firstAngle) - strafeAngle > acceptableRange) {
                        v1correction = increment;
                        v2correction = -increment;
                        v3correction = increment;
                        v4correction = -increment;
                    }
                    fl.setPower(power+v1correction);
                    fr.setPower(power+v2correction);
                    bl.setPower(power+v3correction);
                    br.setPower(power+v4correction);
                }
                break;
            case -1:
                //maybe say gyroTarget *= -1 to make it go the other way?
                if (Math.abs(gyroTarget - getCurrentHeading()) < 5) { //reached target
                    setLastAngle(); //sets the last angle so the next turn will deduct the current angle and make the heading 0
                    turn(0); //set power to 0
                    step = nextStep;
                    sum_error_turn = 0;
                }
                else {
                    //gyroCorrect(gyroTarget);
                    if (gyroTarget > 0) {
                        PIDTurn(); //we runPIDcontrol in order to get adaptable speed
                    }
                    else {
                        gyroCorrect(gyroTarget);
                    }
                }
                break;
            case 0:
                flReached = Math.abs(fl.getCurrentPosition()) >= Math.abs(targetPosition) - 20; //if it's negative it will never stop... but targetPosition would be positive
                frReached = Math.abs(fr.getCurrentPosition()) >= Math.abs(targetPosition) - 20;
                blReached = Math.abs(bl.getCurrentPosition()) >= Math.abs(targetPosition) - 20;
                brReached = Math.abs(br.getCurrentPosition()) >= Math.abs(targetPosition) - 20;

                if (flReached && frReached && blReached && brReached) {
                    //update to see if they are still under the target position
                    step = nextStep;
                    sum_error = 0; //now reset the KI constant
                }
                else {
                    if (!approachBlock) {
                        PIDcontrol();
                    }
                     //uses PID control to adjust the power based on the position relative to the target
                    /**
                     correctAngle();
                     */
                    //if the angle is off, it gets corrected
                }
                break;
            case 1:
                sd = new SkystoneDetection(vuforia); //pass in the engine
                step = 2;
                break;
            case 2:
                pos = sd.vuforiascan(false, true); //save bitmap, and red (on the red side) is true
                if (!pos.equals("NONE")) { //if skystone detected
                    detected = true;
                    blackYellowRatioL2 = SkystoneDetection.blackYellowRatioL;
                    blackYellowRatioC2 = SkystoneDetection.blackYellowRatioC;
                    blackYellowRatioR2 = SkystoneDetection.blackYellowRatioR;
                    if (pos.equals("CENTER")) {
                        numPos = 0;
                    }
                    else if (pos.equals("LEFT")) {
                        numPos = -1;
                    }
                    else { //if position is right
                        numPos = 1;
                    }
                    //telemetry.addData("Skystone Position:", pos);
                    //telemetry.addData("blackYellowRatioL", SkystoneDetection.blackYellowRatioL);
                    //telemetry.addData("blackYellowRatioC", SkystoneDetection.blackYellowRatioC);
                    //telemetry.addData("blackYellowRatioR", SkystoneDetection.blackYellowRatioR);
                    step = -3;
                }
                else {
                    telemetry.addLine("No Visible Target.");
                }
                break;
            //test cases for new driving and turning
            /**
            case 3:
                DriveTrain(8); //go towards the blocks
                targetPosition = calculateTicks(8);
                step = 0;
                nextStep = 4;
                break;
            case 4:
                gyroCorrect(90); //changed to opposite bc
                gyroTarget = 90;
                step = -1;
                nextStep = 5;
                break;
            //strafing method
            case 5:
                strafe(5);
                //targetPosition = calculateTicks(5);
                step = -2;
                nextStep = 6;
                break;
            case 6:
                break;
        `   */
            ///these are the cases for the actual auton
            case 3:
                armLeft.setPosition(.92); //all of these actions take time, so we do them while the robot drives to save time
                strafe(-12);
                step = -2;
                nextStep = 4;
                break;
            case 4:
                DriveTrain(7 * numPos);
                targetPosition = calculateTicks(7 * numPos);
                step = 0;
                nextStep = 5;
                break;
            case 5:
                gyroCorrect(90);
                gyroTarget = 90;
                step = -1;
                nextStep = 6;
                break;
            case 6:
                xrail.setPower(XrailWheelSpeed);
                intakeServo.setPosition(0);
                DriveTrain(8);
                targetPosition = calculateTicks(8);
                step = 0;
                nextStep = 7;
                break;
            case 7:
                xrail.setPower(0);
                approachBlock = true;
                DriveTrain(5);
                targetPosition = calculateTicks(5);
                intakeServo.setPosition(1);
                step = 0;
                nextStep = 8;
                break;
                /**
                approachBlock = false;
                intakeServo.setPosition(1);
                try {
                    Thread.sleep(3000);
                }
                catch (Exception e) {
                    telemetry.addLine("Error with sleep function.");
                }
                step = 8;
                break;
                 */
            case 8:
                approachBlock = false;
                xrail.setPower(-XrailWheelSpeed);
                DriveTrain(-7);
                targetPosition = calculateTicks(-7);
                step = 0;
                nextStep = 9;
                break;
            case 9:
                xrail.setPower(0);
                gyroCorrect(-85); //negative turns don't work
                gyroTarget = -85;
                step = -1;
                nextStep = 10;
                break;
            case 10:
                if (numPos == 0) { //middle block
                    dist += 7;
                }
                else if (numPos == -1){ //left block
                    dist += 14;
                }
                //otherwise it is 0
                DriveTrain(dist);
                targetPosition = calculateTicks(dist);
                step = 0;
                nextStep = 11;
                break;
            case 11:
                break;

            //get the second stone
            case 12:
                intakeServo.setPosition(0); //release the block
                try { //wait to release the block
                    Thread.sleep(1000);
                }
                catch(Exception e){
                }
                intakeServo.setPosition(1); //if we keep set position at 0, we cannot raise the xRail
                dist = -dist - 21; //go backwards, and also -21 inches
                DriveTrain(dist); //go back a negative amount
                targetPosition = dist;
                step = 0;
                nextStep = 13;
                break;
            case 13:
                xrail.setPower(XrailWheelSpeed);
                intakeServo.setPosition(0);
                gyroCorrect(90);
                gyroTarget = 90;
                step = -1;
                nextStep = 14;
                break;
            case 14:
                xrail.setPower(0);
                approachBlock = true;
                DriveTrain(5);
                targetPosition = calculateTicks(5);
                intakeServo.setPosition(1);
                step = 0;
                nextStep = 15;
                break;
            //case 15:







