                //targetPosition = calculateTicks(8);
                try {
                    Thread.sleep(1000);
                }
                catch (Exception e){
                }
                xrail.setPower(0);
                //step = 0;
                step = 14;
                break;
            case 14:
                //xrail.setPower(0); //stop moving the xRail
                intakeServo.setPosition(0); //release the block
                try { //wait to release the block
                    Thread.sleep(500);
                }
                catch(Exception e){
                    telemetry.addLine("Error!");
                }
                DriveTrain(-20); //account for the amount we drove forward
                targetPosition = calculateTicks(-20);
                xrail.setPower(-XrailWheelSpeed);
                step = 0;
                nextStep = -3;
                break;
            case 15:
                intakeServo.setPosition(1); //set the intake position so it doesn't prevent xrail from going up
                xrail.setPower(0);
                //dist is 0 if it is at the right block
                if (dist != 0) { //if the skystone is not the right block, then it is either the middle or left
                    //however, because we cannot grab the block all the way at the left bc it is at the wall
                    //we instead say to grab the middle block, which is -8 + -21

                    //not the right block, it is left or middle
                    //we need to go back -21 inches for the other stone
                    //if it is not 0
                    //-21 + -9
                    dist = -30;
                }
                else { //three blocks away, for the right stone
                    dist = -21;
                }
                xrail.setPower(XrailWheelSpeed); //raise the xRail
                intakeServo.setPosition(0); //open for the grab
                DriveTrain(dist); //go back a negative amount
                targetPosition = calculateTicks(dist);
                step = 0;
                nextStep = 16;
                break;
            case 16:
                xrail.setPower(0);
                gyroCorrect(88); //turn towards the second block
                gyroTarget = 88;
                step = -1;
                nextStep = 17;
                break;
            case 17:
                DriveTrain(11); //we have one case to drive up to the block at full power
                targetPosition = calculateTicks(11);
                step = 0;
                nextStep = 18;
                break;
            case 18:
                approachBlock = true;
                DriveTrain(10); //this case drives at lower power and grabs the block at the same time
                targetPosition = calculateTicks(10);
                intakeServo.setPosition(1);
                step = 0;
                nextStep = 19;
                break;
            case 19:
                approachBlock = false;
                xrail.setPower(-XrailWheelSpeed);
                DriveTrain(-10); //drive back
                targetPosition = calculateTicks(-10);
                step = 0;
                nextStep = 20;
                break;
            case 20:
                xrail.setPower(0);
                gyroCorrect(-88); //negative turns don't work
                gyroTarget = -88;
                step = -1;
                nextStep = 21;
                break;
            case 21:
                DriveTrain(-dist); //now go forward, in the opposite direction
                targetPosition = calculateTicks(-dist);
                step = 0;
                nextStep = 22;
                break;
            case 22:
                DriveTrain(40); //drive to the bridge
                targetPosition = calculateTicks(40);
                step = 0;
                nextStep = -3;
                break;
            case 23:
                xrail.setPower(XrailWheelSpeed);
                try {
                    Thread.sleep(1500);
                }
                catch (Exception e) {
                }
                //step = 0;
                step = 24;
                break;
            case 24:
                xrail.setPower(0); //stop moving the xRail
                intakeServo.setPosition(0); //release the block
                try { //wait to release the block
                    Thread.sleep(500);
                }
                catch(Exception e){
                    telemetry.addLine("Error!");
                }
                step = 25;
                break;
            case 25:
                xrail.setPower(-XrailWheelSpeed);
                DriveTrain(-7); //now drive under the bridge
                targetPosition = calculateTicks(-7);
                step = 0;
                nextStep = 26;
                break;
            case 26:
                xrail.setPower(0);
                telemetry.addLine("Finished!");
                break;
            case 29:
                break;
        }

