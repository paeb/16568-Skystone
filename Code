    @Override
    public void loop() {
        //afterwards switch to state machines
        //get to
        switch(step) {
            case -1:
                if (Math.abs(gyroTarget - getCurrentHeading()) < 1.5) { //reached target
                    setLastAngle(); //sets the last angle so the next turn will deduct the current angle and make the heading 0
                    turn(0); //set power to 0
                    step = nextStep;
                }
                else {
                    gyroCorrect(gyroTarget); //we re-run gyroCorrect in order to get adaptable speed
                }
                break;
            case 0:
                flReached = Math.abs(fl.getCurrentPosition()) >= Math.abs(targetPosition) - 150; //if it's negative it will never stop... but targetPosition would be positive
                frReached = Math.abs(fr.getCurrentPosition()) >= Math.abs(targetPosition) - 150;
                blReached = Math.abs(bl.getCurrentPosition()) >= Math.abs(targetPosition) - 150;
                brReached = Math.abs(br.getCurrentPosition()) >= Math.abs(targetPosition) - 150;

                if (flReached && frReached && blReached && brReached) {
                    //update to see if they are still under the target position
                    step = nextStep;
                }
                else {
                    PIDcontrol(); //uses PID control to adjust the power based on the position relative to the target
                }
                break;

            case 1:
                DriveTrain(15);
                targetPosition = calculateTicks(15);
                step = 0;
                nextStep = 2;
                break;
            case 2:
                gyroCorrect(-90);
                gyroTarget = -90;
                step = -1;
                nextStep = 3;
                break;
            case 3: //this case is to set the encoder starting position (so we know how far to drive)
                encoderStartingPosition = (fl.getCurrentPosition() +
                        fr.getCurrentPosition() + bl.getCurrentPosition() + br.getCurrentPosition()) / 4;
                step = 4;
                break;
            //now it is at the first skystone, so it should keep going until it finds the block
            case 4: //no stop and reset here, so there is not a problem
                //if the skystone is not recognized yet, then it continues to set power to w/o encoders
                try {
                    Thread.sleep(500);
                }
                catch (java.lang.InterruptedException e){
                    telemetry.addLine("Error.");
                }
                skystoneOffset = targetVisible(); //returns the offset. if skystone was not recognized,
                //offset is 0
                if (skystoneOffset != 696969.69) { //if it was recognized, there will be offset not equal to 696969.69
                    simpleDrive(0); //stop the motors
                    step = 5; //go to next Step
                }
                else {
                    simpleDrive(0.1); //keep driving, slowlyu
                    step = 4; //keep executing this case until there is a detection
                }
                break;
            case 5:
                encoderEndingPosition = (fl.getCurrentPosition() + fr.getCurrentPosition() +
                        bl.getCurrentPosition() + br.getCurrentPosition()) / 4; //record the encoder ending position
                step = 6;
                break;
            case 6: //once recognized, we need to correct slightly so skystone is right at the center
                DriveTrain((int)skystoneOffset); //basically now just drive and correct based on the y coordinate
                //actually, lets say we are 1 y coordinate relative to the block. Then we go the opposite direction
                targetPosition = calculateTicks((int)skystoneOffset); //should be minimal
                encoderEndingPosition += -targetPosition; //add the adjustment to the final encoder position as well
                //if we have to move one forward (skystoneOffset is one less), then subtract the ending position
                nextStep = 7;
                step = 0;
                break;
            case 7:
                gyroCorrect(90); //now turn towards the block
                gyroTarget = 90;
                step = -1;
                nextStep = 8;
                break;
            case 8:
                DriveTrain(7); //now go towards the block to pick it up
                targetPosition = calculateTicks(7);
                step = 0;
                nextStep = 9;
                break;
            /**
             * insert servo case here
              */
            case 9:
                DriveTrain(-7); //now go backwards after picking up the block
                targetPosition = calculateTicks(-7);
                step = 0;
                nextStep = 10;
                break;
            case 10:
                gyroCorrect(-90); //turns towards the bridge now
                gyroTarget = -90;
                step = -1;
                if (secondSkystoneDetection) {
                    nextStep = 13; //for the second stone, we have to do something a little different
                }
                else {
                    nextStep = 11;
                }
                break;
            case 11: //drives towards the bridge
                //amount that we have to move back
                encoderMovedPosition = encoderEndingPosition - encoderStartingPosition; //how much we have moved since initial
                //block detection
                //the amount moved should be added to amount towards the bridge, so like 45
                //now convert position to inches...smh

                distanceToDrive
                        = (encoderMovedPosition / ticksPerTurn * wheelCircum);

                DriveTrain((int)(distanceToDrive)); //drive towards the first block, with the encoder
                //difference and also distance to go under skybridge from first stone, which 45 inches
                targetPosition = calculateTicks((int)(distanceToDrive));
                nextStep = 12;
                step = 0;
                break;
            /**
             * add cases to drop block, move foundation, etc here
              */
            case 12:
                //now drive back and detect the second, we know where it is generally
                //just append the distance of two blocks, since that's how far away the blocks are in auton

                //each stone is 7 inches wide, so extra 21 inches (3 in between)
                try {
                    Thread.sleep(1000);
                }
                catch (java.lang.InterruptedException e) {
                    telemetry.addLine("f");
                }
                DriveTrain(-(int)(distanceToDrive + 21)); //go back the same amount plus extra 21 inches for three blocks
                targetPosition = calculateTicks(-(int)(distanceToDrive + 21)); //get the number of ticks


                /**
                DriveTrain(-25);
                targetPosition = calculateTicks(-25);
                 */
                nextStep = 4; //we are reusing the adjustment case from case 4 and the code onwards
                step = 0;
                secondSkystoneDetection = true; //now that we are going for the second skystone detection,
                //we can reuse certain cases with slight adjustments
                break;
            case 13:
                //after adjustment and proper turns, drive back to the bridge
                DriveTrain((int)(distanceToDrive + 21 - skystoneOffset));
                targetPosition = calculateTicks((int)(distanceToDrive + 21 - skystoneOffset));
                nextStep = 14;
                step = 0;
                break;
                //we would subtract the skystone offset
                //if the offset was -1, then we go an extra 1 inch
            case 14:
                break;
        }

        /**
         telemetry.addLine("fl: " + fl.getCurrentPosition());
         telemetry.addLine("fr: " + fr.getCurrentPosition());
         telemetry.addLine("bl: " + bl.getCurrentPosition());
         telemetry.addLine("br: " + br.getCurrentPosition());
         telemetry.addLine("red" + colorSensor.red());
         telemetry.addLine("blue" + colorSensor.blue());
         telemetry.addLine("green" + colorSensor.green());
         telemetry.update();
         */

        telemetry.addData("Current Heading/Angle:", getCurrentHeading());
        telemetry.addData("fl: ", fl.getCurrentPosition());
        telemetry.addData("fr: ", fr.getCurrentPosition());
        telemetry.addData("br: ", fr.getCurrentPosition());
        telemetry.addData("bl: ", fr.getCurrentPosition());
        telemetry.addData("target position: ", targetPosition);
        telemetry.addData("case: ", step);
        if (step == 12) {
            hasHitCase12 = true;
        }
        telemetry.addData("has gone to case 12", hasHitCase12);
        telemetry.addData("skystone error: ", skystoneOffset);
        telemetry.addData("Skystone distance:", distanceToDrive);
        //telemetry.addData("Difference", Math.abs(gyroTarget - getCurrentHeading()));
        telemetry.update();

    }
